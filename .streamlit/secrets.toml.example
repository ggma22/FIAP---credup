# =====================================================================
# CredUp — Streamlit Cloud secrets.toml (EXEMPLO)
# =====================================================================
# Este arquivo é APENAS um TEMPLATE. NÃO suba o secrets.toml real
# para o GitHub. Cole o conteúdo abaixo na interface do Streamlit
# Cloud em: App settings → Secrets.
#
# A wallet do Oracle Autonomous DB precisa ser embarcada como base64.
# Para gerar:
#
#   # Linux:
#   base64 -w 0 wallet_credup.zip
#
#   # macOS:
#   base64 -i wallet_credup.zip | tr -d '\n' | pbcopy
#
#   # Windows PowerShell:
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("wallet_credup.zip"))
#
# =====================================================================

[oracle]
ORACLE_USER     = "credup_app"
ORACLE_PASSWORD = "TrocarPorSenhaForte"
ORACLE_DSN      = "g78a19v19gru1pbr_medium"

# Cole o base64 do .zip da wallet inteiro entre aspas.
# (O app decodifica em /tmp/credup_wallet em runtime)
ORACLE_WALLET_B64 = "PKK...COLE_AQUI_O_BASE64_GIGANTE_DA_WALLET..."

# Senha da wallet (definida ao baixar pelo OCI Console)
ORACLE_WALLET_PASSWORD = "SenhaDaWallet"
