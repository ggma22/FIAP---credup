# =====================================================================
# CredUp — variáveis de ambiente
# =====================================================================
# Copie este arquivo para `.env` e preencha com suas credenciais.
# O `.env` está no .gitignore — NUNCA suba ele para o GitHub.
#
# Se nenhuma variável Oracle for definida, o app usa CSV automaticamente
# (modo demo / fallback).
# =====================================================================

# --- Oracle Autonomous Database ---
# Usuário do banco. Para o app, recomendamos um usuário dedicado de
# leitura (ex: credup_app) em vez do ADMIN — princípio de menor privilégio.
ORACLE_USER=credup_app

# Senha do usuário
ORACLE_PASSWORD=TrocarPorSenhaForte

# Connection string. No Autonomous DB, vem do tnsnames.ora dentro da wallet.
# Exemplos: <db_name>_high, <db_name>_medium, <db_name>_low
# Use _medium para o dashboard (bom equilíbrio entre paralelismo e latência).
ORACLE_DSN=g78a19v19gru1pbr_medium

# --- Autenticação mTLS via wallet (Oracle Autonomous DB) ---
# Caminho ABSOLUTO para a pasta onde a wallet foi descompactada
# (a pasta com cwallet.sso, tnsnames.ora, sqlnet.ora, etc.)
ORACLE_WALLET_DIR=C:\Users\seu_usuario\wallet_credup

# Senha da wallet (definida ao baixar a wallet pelo OCI Console).
ORACLE_WALLET_PASSWORD=SenhaDaWallet
